{
  "name": "@imenam/refactoring-mcp",
  "version": "1.0.0",
  "description": "MCP server to copy or move code blocks between files, with optional directory confinement.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "refactoring-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "refactoring",
    "code",
    "move",
    "copy",
    "model-context-protocol"
  ],
  "author": "imenam",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/imenam/refactoring-mcp.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
